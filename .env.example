# Server-side AI key for the free trial API.
# Fill these in Vercel Project Settings -> Environment Variables.
AI_API_KEY=sk-your-server-key
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini

# Local Vite dev proxy target for /api.
VITE_FREE_API_BASE_URL=https://word-brawl.vercel.app

# Default is 10. Set to 0 for unlimited free trial usage.
FREE_DAILY_LIMIT=10

# Daily quota reset timezone.
FREE_USAGE_TIMEZONE=Asia/Shanghai

# Optional: only allow a specific cross-origin caller.
# Same-origin calls from the deployed frontend work without this.
ALLOWED_ORIGIN=https://word-brawl.vercel.app

# Optional: stable salt for hashing client IPs in quota storage.
USAGE_HASH_SALT=replace-with-random-string
